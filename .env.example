# Copy this file to .env before running Docker Compose.
# Keep real production secrets out of git.

COMPOSE_PROJECT_NAME=e-commerce-microservices

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_HOST_PORT=5434
POSTGRES_CONTAINER_PORT=5432
POSTGRES_USER=postgres
POSTGRES_DEFAULT_DB=postgres
DB_PASSWORD=postgres
USER_DB=users
PRODUCT_CATALOG_DB=product_catalog
ORDER_DB=orders
PRODUCT_RECOMMENDATION_DB=product_recommendations
PAYMENT_DB=payments
NOTIFICATION_DB=notifications

# Redis
REDIS_HOST=redis
REDIS_HOST_PORT=6379
REDIS_PORT=6379

# MongoDB
MONGO_HOST=mongo
MONGO_HOST_PORT=27017
MONGO_PORT=27017
MONGO_DATABASE=notifications

# Kafka and Zookeeper
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_CLIENT_PORT=2181
KAFKA_HOST=kafka
KAFKA_HOST_PORT=9092
KAFKA_EXTERNAL_PORT=9092
KAFKA_INTERNAL_PORT=29092
KAFKA_SERVERS=kafka:29092

# Eureka
EUREKA_HOST=eureka-server
EUREKA_PORT=8761
EUREKA_SERVER_URL=http://eureka-server:8761/eureka
EUREKA_INSTANCE_PREFER_IP_ADDRESS=true

# Required: generate a unique value with at least 32 random bytes before starting Compose.
# Example generator: openssl rand -base64 48
SECURITY_JWT_SECRET=
SECURITY_JWT_EXPIRATION_MS=86400000

# Spring Boot service ports
API_GATEWAY_PORT=8900
USER_SERVICE_PORT=8811
PRODUCT_CATALOG_SERVICE_PORT=8812
ORDER_SERVICE_PORT=8813
PRODUCT_RECOMMENDATION_SERVICE_PORT=8814
PAYMENT_SERVICE_PORT=8815
NOTIFICATION_SERVICE_PORT=8816

# Gateway routes
USER_SERVICE_URI=lb://user-service
PRODUCT_CATALOG_SERVICE_URI=lb://product-catalog-service
ORDER_SERVICE_URI=lb://order-service
PAYMENT_SERVICE_URI=lb://payment-service
NOTIFICATION_SERVICE_URI=lb://notification-service
PRODUCT_RECOMMENDATION_SERVICE_URI=lb://product-recommendation-service

# User service / Firebase Admin
SERVER_URL=http://user-service:8811
FIREBASE_CONFIG_PATH=/run/secrets/firebase-service-account.json

# Transactional email
# Use a Gmail App Password, never the normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_STORE_NAME=RainbowForest

# Online payment gateways
# These values must come from your own VNPay and MoMo merchant accounts.
# Leave credentials empty to keep the gateway disabled; never commit real values.
FRONTEND_BASE_URL=http://localhost:5173
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8900/api/payments/vnpay/return
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_CREATE_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:8900/api/payments/momo/return
MOMO_NOTIFY_URL=http://localhost:8900/api/payments/momo/ipn

# AI Chatbot configuration
# Google Gemini API key (e.g. gemini-1.5-flash or gemini-2.0-flash / gemini-2.5-flash / gemini-3.1-flash / etc.)
GEMINI_API_KEY=

